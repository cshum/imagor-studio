{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "types": ["vite/client", "node"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../web/src/*"],
      "@cloud/*": ["../../web/src/cloud/*"],
      "@/components/ui/*": ["../../shared/web/src/components/ui/*"],
      "@/layouts/spaces-layout": ["../../shared/web/src/layouts-spaces-layout"],
      "@/components/ui/checkbox": ["../../shared/web/src/components/ui/checkbox"],
      "@/components/ui/select": ["../../shared/web/src/components/ui/select"],
      "@/components/ui/radio-group": ["../../shared/web/src/components/ui/radio-group"],
      "@/components/ui/toggle-group": ["../../shared/web/src/components/ui/toggle-group"],
      "@/components/ui/context-menu": ["../../shared/web/src/components/ui/context-menu"],
      "@/components/ui/textarea": ["../../shared/web/src/components/ui/textarea"],
      "@shared/*": ["../../shared/web/src/*"],
      "@radix-ui/react-checkbox": ["../../web/node_modules/@radix-ui/react-checkbox"],
      "@radix-ui/react-select": ["../../web/node_modules/@radix-ui/react-select"],
      "@radix-ui/react-radio-group": ["../../web/node_modules/@radix-ui/react-radio-group"],
      "@radix-ui/react-toggle-group": ["../../web/node_modules/@radix-ui/react-toggle-group"],
      "@radix-ui/react-context-menu": ["../../web/node_modules/@radix-ui/react-context-menu"],
      "react": ["../../web/node_modules/react"],
      "react/jsx-runtime": ["../../web/node_modules/react/jsx-runtime"],
      "react-hook-form": ["../../web/node_modules/react-hook-form"],
      "react-i18next": ["../../web/node_modules/react-i18next"],
      "lucide-react": ["../../web/node_modules/lucide-react"],
      "@radix-ui/react-label": ["../../web/node_modules/@radix-ui/react-label"],
      "@radix-ui/react-slot": ["../../web/node_modules/@radix-ui/react-slot"],
      "@radix-ui/react-dropdown-menu": ["../../web/node_modules/@radix-ui/react-dropdown-menu"],
      "@radix-ui/react-dialog": ["../../web/node_modules/@radix-ui/react-dialog"],
      "@radix-ui/react-tooltip": ["../../web/node_modules/@radix-ui/react-tooltip"],
      "@radix-ui/react-collapsible": ["../../web/node_modules/@radix-ui/react-collapsible"],
      "@tanstack/react-router": ["../../web/node_modules/@tanstack/react-router"],
      "clsx": ["../../web/node_modules/clsx"],
      "tailwind-merge": ["../../web/node_modules/tailwind-merge"],
      "class-variance-authority": ["../../web/node_modules/class-variance-authority"],
      "radix-ui": ["../../web/node_modules/radix-ui"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
